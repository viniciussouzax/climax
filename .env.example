# Copy to .env and fill in. Never commit the real .env.

# Key the CRM (or any OpenAI client) must send as: Authorization: Bearer <key>
NEXUS_CLI_API_KEY=change-me-to-a-long-random-string

# Claude authentication. Use your Claude Code OAuth token (Max) ...
CLAUDE_CODE_OAUTH_TOKEN=

# ... OR, instead of the Max token, an Anthropic API key the claude CLI trusts:
# ANTHROPIC_API_KEY=

# Optional — basics
PORT=8088
NEXUS_CLI_MODEL_ID=nexus-cli

# Concurrency pool. Requests above this size WAIT in an unbounded FIFO queue and
# are never rejected, expired, or dropped — every request is eventually served.
NEXUS_CLI_MAX_CONCURRENCY=12

# Per-RUN anti-freeze (NOT a queue limit): if a single `claude` process wedges,
# it is killed after this long so its worker slot returns to the pool instead of
# stalling everyone behind it. Set generously; a normal reply takes ~10s.
NEXUS_CLI_TIMEOUT_MS=180000
