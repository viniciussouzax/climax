# Copy to .env and fill in. Never commit the real .env.

# Key the CRM (or any OpenAI client) must send as: Authorization: Bearer <key>
NEXUS_CLI_API_KEY=change-me-to-a-long-random-string

# Claude authentication. Use your Claude Code OAuth token (Max) ...
CLAUDE_CODE_OAUTH_TOKEN=

# ... OR, instead of the Max token, an Anthropic API key the claude CLI trusts:
# ANTHROPIC_API_KEY=

# Optional — basics
PORT=8088
NEXUS_CLI_MODEL_ID=nexus-cli
NEXUS_CLI_TIMEOUT_MS=180000           # per-request hard timeout for one claude run

# Optional — concurrency pool + FIFO queue (Cloud Run / Apify style).
# Requests above the pool size WAIT in the queue (they are not rejected); a
# queued request starts as soon as a worker frees up. Backpressure only kicks
# in (HTTP 503) when the queue is full or a request waits past the timeout.
NEXUS_CLI_MAX_CONCURRENCY=12          # how many claude runs in parallel (pool size)
NEXUS_CLI_MAX_QUEUE=200               # max requests allowed to wait for a free worker
NEXUS_CLI_QUEUE_TIMEOUT_MS=90000      # max time a request may sit in the queue before 503
