# Copy to .env and fill in. Never commit the real .env.

# Key the CRM (or any OpenAI client) must send as: Authorization: Bearer <key>
CLIMAX_API_KEY=change-me-to-a-long-random-string

# Claude authentication. Use your Claude Code OAuth token (Max) ...
CLAUDE_CODE_OAUTH_TOKEN=

# ... OR, instead of the Max token, an Anthropic API key the claude CLI trusts:
# ANTHROPIC_API_KEY=

# Optional — basics
PORT=8088
CLIMAX_MODEL_ID=climax

# Concurrency pool. Requests above this size wait in a FIFO queue (see
# CLIMAX_MAX_QUEUE). Queued requests start the instant a worker frees up.
CLIMAX_MAX_CONCURRENCY=12

# Backpressure: max requests waiting in the FIFO queue. Beyond this the server
# sheds load with HTTP 429 + Retry-After so clients back off and retry instead
# of piling up until the process OOMs.
CLIMAX_MAX_QUEUE=200

# Per-RUN anti-freeze (NOT a queue limit): if a single `claude` process wedges,
# it is killed after this long (request gets HTTP 504). Set generously; a
# normal reply takes ~10s.
CLIMAX_TIMEOUT_MS=180000

# Automatic retries (with backoff) for transient `claude` failures — auth blips,
# upstream 5xx, empty-stderr exit 1. Rate limits and input errors are NOT retried.
CLIMAX_RETRIES=2

# Optional model routing. Requests whose `model` looks like a Claude model or
# alias (sonnet/opus/haiku/claude-*) are passed to `claude --model` as-is;
# anything else (e.g. "climax") uses CLIMAX_DEFAULT_MODEL, or the CLI default
# if empty. CLIMAX_FALLBACK_MODEL adds `--fallback-model` for overload failover.
CLIMAX_DEFAULT_MODEL=
CLIMAX_FALLBACK_MODEL=
