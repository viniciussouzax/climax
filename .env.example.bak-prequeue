# Copy to .env and fill in. Never commit the real .env.

# Key the CRM (or any OpenAI client) must send as: Authorization: Bearer <key>
NEXUS_CLI_API_KEY=change-me-to-a-long-random-string

# Claude authentication. Use your Claude Code OAuth token (Max) ...
CLAUDE_CODE_OAUTH_TOKEN=

# ... OR, instead of the Max token, an Anthropic API key the claude CLI trusts:
# ANTHROPIC_API_KEY=

# Optional
PORT=8088
NEXUS_CLI_MODEL_ID=nexus-cli
NEXUS_CLI_TIMEOUT_MS=180000
NEXUS_CLI_MAX_CONCURRENCY=4
